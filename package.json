{
  "name": "travian-elephant-finder",
  "version": "1.0.0",
  "description": "CLI tool to scan Travian map oases and find elephant locations",
  "license": "MIT",
  "keywords": ["travian", "oasis", "elephant", "cli", "game-tool"],
  "repository": {
    "type": "git",
    "url": "https://github.com/tegos/travian-elephant-finder.git"
  },
  "imports": {
    "#src/*": "./src/*",
    "#root/*": "./*"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cheerio": "^1.2.0",
    "cli-progress": "^3.12.0",
    "dotenv": "^17.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "Myhkavko Ivan",
  "scripts": {
    "setup": "node scripts/setup.js",
